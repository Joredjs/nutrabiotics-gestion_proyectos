{
  "name": "nutrabiotics-system-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "implicitDependencies": ["nutrabiotics-system"],
  "targets": {
    "e2e": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{e2eProjectRoot}"],
      "options": {
        "jestConfig": "apps/nutrabiotics-system-e2e/jest.config.ts",
        "passWithNoTests": true
      },
      "dependsOn": ["nutrabiotics-system:build", "nutrabiotics-system:serve"]
    }
  }
}
